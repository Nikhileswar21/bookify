<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>allbooks
    </title>
</head>
<body>
    <h1>Books</h1>
    <% if (books.length == 0) { %>
        <p>No books found</p>
     
    <% }else { %>
        <table>
        <thead>
            <tr>
                <th>SI. no</th>
                <th>Title</th>
                <th>Author</th>
                <th>Price</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% books.forEach((book , index)=> { %>
                <tr>
                    <td> <%= index + 1 %> </td>
                    <td><a href ="/books/<%= book._id %>"><%= book.Bookname %></a></td>
                    <td><%= book.Author %></td>
                    <td><%= book.Price %></td>
                    <td><button onclick="deleteBook('<%= book._id %>')">Delete</button></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
        <% }%>
        <script>
            async function deleteBook(bookId){
                await fetch(`/books/${bookId}`, {
                    method: 'DELETE'
                });
                window.location.reload();
            }
        </script>

</body>
</html>