<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>allbooks
    </title>
</head>
<body>
    <h1>Books</h1>
    <% if (books.length == 0) { %>
        <p>No books found</p>
     
    <% }else { %>
        <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
            </tr>
        </thead>
        <tbody>
            <% books.forEach(book => { %>
                <tr>
                    <td><%= book.id %></td>
                    <td><%= book.title %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>
        <% }%>

</body>
</html>